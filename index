<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เครื่องคิดเลข ไทยช่วยไทย พลัส 60:40</title>
    <!-- โหลด Tailwind CSS สำหรับการจัดรูปแบบให้สวยงามและรองรับมือถือ -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- โหลดฟอนต์ Google Fonts (Kanit) เพื่อให้อ่านง่ายและดูเป็นทางการ -->
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Kanit', sans-serif;
            /* ย้ายสีพื้นหลังไปใส่ในคลาสของ Tailwind ด้านล่างแทนเพื่อให้ไล่สีได้สวยงาม */
        }
        /* ซ่อนลูกศรใน input type number */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }
        input[type=number] {
            -moz-appearance: textfield;
        }
    </style>
</head>
<body class="min-h-screen p-4 flex flex-col items-center justify-center bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">

    <!-- เพิ่มชาโดว์ที่เข้มขึ้น (shadow-2xl), ปรับขอบให้มนขึ้น (rounded-3xl) และเพิ่มเส้นขอบบางๆ เพื่อสร้างมิติ -->
    <div class="w-full max-w-md bg-white rounded-3xl shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)] border border-blue-200 overflow-hidden relative">
        
        <!-- แสงสะท้อนบางๆ ด้านบนกล่องเพื่อเพิ่มมิติ 3D -->
        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-white/60 to-transparent pointer-events-none"></div>

        <!-- ส่วนหัว -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white p-6 text-center relative shadow-sm border-b border-blue-700">
            <h1 class="text-2xl font-bold tracking-wide drop-shadow-md">ไทยช่วยไทย พลัส 60:40</h1>
            <p class="text-blue-100 text-sm mt-1 opacity-90">โปรแกรมช่วยคำนวนยอดสแกนสำหรับผู้ประกอบการ</p>
        </div>

        <div class="p-6 space-y-6">
            
            <!-- ส่วนที่ 1: กรอกข้อมูล -->
            <div class="space-y-5">
                <!-- ราคาสินค้า -->
                <div>
                    <label class="block text-gray-700 text-sm font-semibold mb-2" for="price">
                        ราคาสินค้าทั้งหมด (บาท)
                    </label>
                    <input type="number" id="price" placeholder="0" class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/20 focus:outline-none text-2xl text-right font-bold transition-all shadow-inner" oninput="calculate()">
                </div>

                <!-- สิทธิรัฐที่เหลือ -->
                <div>
                    <label class="block text-gray-700 text-sm font-semibold mb-2" for="subsidy">
                        สิทธิรัฐที่ลูกค้าเหลืออยู่ (บาท)
                    </label>
                    <div class="relative">
                        <input type="number" id="subsidy" value="200" placeholder="0 - 200" class="w-full px-4 py-3 rounded-xl border-2 border-orange-200 focus:border-orange-500 focus:ring-4 focus:ring-orange-500/20 focus:outline-none text-xl text-right font-bold transition-all text-orange-600 shadow-inner" oninput="calculate()">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="text-gray-400 text-sm font-medium">สูงสุด 200</span>
                        </div>
                    </div>
                    
                    <!-- ปุ่ม Quick Fill สำหรับกดรวดเร็ว -->
                    <div class="flex gap-2 mt-3">
                        <button onclick="setSubsidy(200)" class="flex-1 bg-orange-50 hover:bg-orange-100 border border-orange-200 text-orange-700 py-1.5 rounded-lg text-sm font-medium transition-colors shadow-sm active:scale-95">เต็ม 200</button>
                        <button onclick="setSubsidy(100)" class="flex-1 bg-orange-50 hover:bg-orange-100 border border-orange-200 text-orange-700 py-1.5 rounded-lg text-sm font-medium transition-colors shadow-sm active:scale-95">เหลือ 100</button>
                        <button onclick="setSubsidy(50)" class="flex-1 bg-orange-50 hover:bg-orange-100 border border-orange-200 text-orange-700 py-1.5 rounded-lg text-sm font-medium transition-colors shadow-sm active:scale-95">เหลือ 50</button>
                        <button onclick="setSubsidy(0)" class="flex-1 bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-600 py-1.5 rounded-lg text-sm font-medium transition-colors shadow-sm active:scale-95">หมด (0)</button>
                    </div>
                </div>
            </div>

            <hr class="border-gray-200 border-dashed">

            <!-- ส่วนที่ 2: สรุปผลการคำนวณยอดปัจจุบัน -->
            <div class="space-y-4">
                
                <!-- ยอดที่ต้องกดสแกนแอปถุงเงิน -->
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-2xl p-4 flex justify-between items-center shadow-sm">
                    <div>
                        <p class="text-blue-900 font-bold">1. กดสแกนแอป "ถุงเงิน"</p>
                        <p class="text-blue-600 text-xs mt-0.5">ยอดร่วมจ่าย (สิทธิรัฐ + G-Wallet)</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-black text-blue-700" id="scan-amount">0.00 ฿</p>
                    </div>
                </div>

                <!-- ยอดที่ถูกหักจากเป๋าตังลูกค้า -->
                <div class="flex justify-between items-center px-3 py-2 text-sm text-gray-500 bg-gray-50/80 rounded-lg border border-gray-100">
                    <p>» หักเงินจาก G-Wallet ลูกค้า:</p>
                    <p id="wallet-amount" class="font-semibold text-gray-700">0.00 ฿</p>
                </div>

                <!-- ยอดเงินสดที่ต้องเก็บเพิ่ม -->
                <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-2xl p-4 flex justify-between items-center shadow-sm">
                    <div>
                        <p class="text-green-900 font-bold">2. เก็บเงินสด / โอนแยก</p>
                        <p class="text-green-600 text-xs mt-0.5">ส่วนต่างที่เกินสิทธิโครงการ</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-black text-green-600 drop-shadow-sm" id="cash-amount">0.00 ฿</p>
                    </div>
                </div>

            </div>

            <!-- ส่วนที่ 3: ข้อมูลสิทธิคงเหลือและกำลังซื้อ -->
            <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-4 shadow-inner space-y-3 relative overflow-hidden">
                <!-- แถบสีตกแต่ง -->
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-indigo-400"></div>
                
                <h3 class="text-indigo-800 font-bold text-sm flex items-center gap-2 pl-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    ข้อมูลสิทธิคงเหลือ (หลังทำรายการนี้)
                </h3>
                
                <div class="flex justify-between items-center text-sm pl-2">
                    <span class="text-gray-600">สิทธิรัฐช่วยที่เหลืออยู่:</span>
                    <span id="remaining-subsidy" class="font-bold text-indigo-600 text-lg">0.00 ฿</span>
                </div>
                
                <div class="bg-white/80 rounded-xl p-3 text-sm space-y-2 border border-white shadow-sm">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600 text-xs">ซื้อของเพิ่มได้สูงสุดอีก:</span>
                        <span id="future-buying-power" class="font-bold text-gray-800">0.00 ฿</span>
                    </div>
                    <div class="w-full h-px bg-gray-100"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600 text-xs">ต้องมี G-Wallet จ่ายสมทบ:</span>
                        <span id="future-wallet-needed" class="font-semibold text-gray-700">0.00 ฿</span>
                    </div>
                </div>
            </div>

        </div>
        
        <!-- ส่วนท้ายกระดาษ -->
        <div class="bg-gray-50 border-t border-gray-100 p-4 text-center text-xs text-gray-400">
            คำนวณจากสูตร: รัฐช่วย 60% สูงสุด 200 บ./วัน
        </div>
    </div>

    <!-- เครดิตผู้พัฒนา -->
    <div class="mt-6 text-center text-blue-200/70 text-sm font-light tracking-wide drop-shadow-sm">
        พัฒนาโดย <span class="font-medium text-white/90">SARAWUT SRT</span> ด้วย Gemini AI
    </div>

    <script>
        // ฟังก์ชันตั้งค่าสิทธิคงเหลือแบบด่วน
        function setSubsidy(amount) {
            document.getElementById('subsidy').value = amount;
            calculate();
        }

        // ฟังก์ชันหลักในการคำนวณ
        function calculate() {
            // ดึงค่าจากช่อง input ถ้าไม่มีค่าให้เป็น 0
            let price = parseFloat(document.getElementById('price').value) || 0;
            let subsidy = parseFloat(document.getElementById('subsidy').value) || 0;

            // จำกัดสิทธิสูงสุดไม่เกิน 200 บาท
            if (subsidy > 200) {
                subsidy = 200;
                document.getElementById('subsidy').value = 200;
            }

            let scanAmount = 0;
            let walletAmount = 0;
            let cashAmount = 0;
            let usedSubsidy = 0; // ตัวแปรใหม่สำหรับเก็บสิทธิที่ถูกใช้ไปในบิลนี้

            if (price > 0) {
                // คำนวณส่วนที่รัฐจะต้องจ่าย (60% ของราคาสินค้า)
                let govShareIfFull = price * 0.6;

                if (govShareIfFull <= subsidy) {
                    // กรณีที่ 1: สิทธิรัฐยังเหลือพอที่จะจ่าย 60% ของราคาสินค้าชิ้นนี้
                    scanAmount = price;
                    walletAmount = price * 0.4;
                    cashAmount = 0;
                    usedSubsidy = govShareIfFull; // ใช้สิทธิตามจริง 60%
                } else {
                    // กรณีที่ 2: สิทธิรัฐมีไม่พอ ต้องรูดจนหมดสิทธิ
                    scanAmount = subsidy / 0.6;
                    walletAmount = scanAmount * 0.4;
                    cashAmount = price - scanAmount;
                    usedSubsidy = subsidy; // ใช้สิทธิไปจนหมดแม็กซ์ที่มี
                }
            }

            // --- การคำนวณสิทธิคงเหลือสำหรับอนาคต ---
            let newRemainingSubsidy = Math.max(0, subsidy - usedSubsidy);
            
            // สูตรคำนวณกำลังซื้อ: ยอดซื้อสูงสุด = สิทธิที่เหลือ / 0.6
            let futureBuyingPower = newRemainingSubsidy / 0.6;
            let futureWalletNeeded = futureBuyingPower * 0.4;

            // แสดงผลลัพธ์ส่วนทำรายการ (ปัดเศษทศนิยม 2 ตำแหน่ง)
            document.getElementById('scan-amount').innerText = scanAmount.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';
            document.getElementById('wallet-amount').innerText = walletAmount.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';
            document.getElementById('cash-amount').innerText = cashAmount.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';

            // แสดงผลลัพธ์ส่วนสิทธิคงเหลือ
            document.getElementById('remaining-subsidy').innerText = newRemainingSubsidy.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';
            document.getElementById('future-buying-power').innerText = futureBuyingPower.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';
            document.getElementById('future-wallet-needed').innerText = futureWalletNeeded.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' ฿';
        }

        // คำนวณครั้งแรกเมื่อโหลดหน้าเว็บ
        window.onload = calculate;
    </script>
</body>
</html>
